# Ignore macOS DS_Store files
.DS_Store

# Ignore editor state
.vscode/
.idea/

# Ignore Python interpreter caches
__pycache__/
*.py[cod]

# Ignore Python test caches and coverage output
.pytest_cache/
.coverage
htmlcov/

# Ignore virtual environments
.venv/
venv/
env/

# Ignore build artifacts
build/
dist/
*.egg-info/

# Ignore Go and Java build output
bin/
target/
.gradle/

# Ignore logs and temporary files
*.log
logs/
tmp/
temp/
var/

# Ignore user-local AI assistant context
AI_CONTEXT.md
